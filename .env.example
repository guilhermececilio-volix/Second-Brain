# Copie este arquivo para .env e preencha com seus valores reais.
# O .env NUNCA vai para o Git (já está no .gitignore).

# Chave do Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=coloque-sua-chave-aqui


# Modelos (opcional — estes são os padrões)
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Sprint 2 — banco de dados (pgvector)
# Estes valores batem com o docker-compose.yml do projeto.
# DATABASE_URL=postgresql://second_brain:second_brain@localhost:5432/second_brain

# Sprint 2 — caminho do vault do Obsidian
# OBSIDIAN_VAULT_PATH=C:\caminho\para\seu\vault
